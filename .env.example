# Free virtual try-on — uses public Hugging Face Gradio AI (no paid keys).
# Optional: HF_TOKEN — free read token from https://huggingface.co/settings/tokens
# Gives more GPU quota on Hugging Face Spaces (still 100% free, no credit card).

# Google Gemini API — try-on fallback + refine features
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# FASHN API — OPTIONAL PAID (~$7.50 minimum credits, ~$0.075/image). Not required.
# Only used if you set FASHN_API_KEY below. Free path: HF + Gemini only.
# https://fashn.ai/products/api
FASHN_API_KEY=""

# Optional: your forked IDM-VTON Hugging Face Spaces for extra free GPU quota
# Example: HF_TRYON_SPACES="your-username/IDM-VTON"
HF_TRYON_SPACES=""

# Fashion API Keys for Trending Bot (optional — mock data used if missing)
UNSPLASH_ACCESS_KEY="HLvPtuNUrRxrP69KjRV6AT1SGCzR3qBydjTnNRA9Eqg"
PEXELS_API_KEY="54883068-331f50eb77739b16e2f9d2e5a"
PIXABAY_API_KEY="bvm8QKsOw5YucpwwjzaZZyoUBufAy5MI3X8SnZr4WQ0fEUhyDERM2BLu"

# Hugging Face API (Stable Diffusion)
# Get your free API key from: https://huggingface.co/settings/tokens
# 1. Go to huggingface.co and sign up/login
# 2. Click profile picture → "Access Tokens" 
# 3. Click "Create New Token" → Name it "fashion-app"
# 4. Select "Read" permissions → Click "Create token"
# 5. Copy the token and paste below
